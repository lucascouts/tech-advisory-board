#!/usr/bin/env bash
# open-timeline — render (if needed) and open the session timeline HTML
# in the user's default browser.
#
# Usage:
#   open-timeline [<session-id|session-dir>]
#   open-timeline --latest          (default)
#   open-timeline --no-open         (render but do not launch browser)
#
# If no argument is given, uses the newest non-archived session under
# <cwd>/.tab/sessions/. The HTML is (re-)generated by
# scripts/render-timeline.sh when missing; existing HTMLs are not
# overwritten unless --force is passed.
set -uo pipefail

TAB_ROOT="${CLAUDE_PROJECT_DIR:-$PWD}/.tab"
ARG="${1:---latest}"
FORCE=false
NO_OPEN=false

for a in "$@"; do
    case "$a" in
        --force)    FORCE=true ;;
        --no-open)  NO_OPEN=true ;;
    esac
done

resolve_session_dir() {
    local a="$1"
    if [[ -d "$a" ]]; then
        printf '%s' "$a"; return 0
    fi
    if [[ -d "$TAB_ROOT/sessions/$a" ]]; then
        printf '%s' "$TAB_ROOT/sessions/$a"; return 0
    fi
    return 1
}

if [[ "$ARG" == "--latest" || "$ARG" == "--force" || "$ARG" == "--no-open" ]]; then
    # find newest session
    if [[ ! -d "$TAB_ROOT/sessions" ]]; then
        echo "No .tab/sessions directory under $TAB_ROOT" >&2
        exit 1
    fi
    SESSION_DIR=$(ls -1dt "$TAB_ROOT"/sessions/*/ 2>/dev/null | head -n1 | sed 's:/*$::')
    [[ -n "$SESSION_DIR" ]] || { echo "No sessions found" >&2; exit 1; }
else
    SESSION_DIR=$(resolve_session_dir "$ARG") || {
        echo "Session not found: $ARG" >&2
        exit 1
    }
fi

HTML="$SESSION_DIR/timeline.html"
if [[ ! -f "$HTML" || "$FORCE" == "true" ]]; then
    "${CLAUDE_PLUGIN_ROOT:-$PWD}/scripts/render-timeline.sh" "$SESSION_DIR" >/dev/null
fi

printf '%s\n' "$HTML"
[[ "$NO_OPEN" == "true" ]] && exit 0

if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "file://$HTML" 2>/dev/null &
elif command -v open >/dev/null 2>&1; then
    open "file://$HTML" &
elif [[ -n "${BROWSER:-}" ]]; then
    "$BROWSER" "file://$HTML" &
else
    echo "(could not auto-open — no xdg-open/open/$BROWSER; copy the path above)" >&2
fi
