{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/detect-interrupted.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-tab-context.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/flush-state.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 4,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/rehydrate-state.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "if": "Write(**/TAB/sessions/**)",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/update-telemetry.sh"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 2,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/on-task-created.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/update-telemetry-subagent.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-on-stop.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 4,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/on-stop-failure.sh"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 2,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/on-reactive-change.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "if": "TAB/**",
        "hooks": [
          {
            "type": "command",
            "timeout": 2,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/on-reactive-change.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/archive-idle-sessions.sh"
          }
        ]
      }
    ]
  }
}
