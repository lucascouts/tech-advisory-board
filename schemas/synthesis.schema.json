{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tech-advisory-board/synthesis.schema.json",
  "title": "TAB Synthesis",
  "description": "Canonical structured output of a TAB session. Consumer contract documented in  and skills/tab/references/synthesis-schema.md.",
  "type": "object",
  "required": [
    "tab_version",
    "schema_version",
    "session",
    "context",
    "landscape",
    "recommendation",
    "risks"
  ],
  "properties": {
    "tab_version": {
      "type": "string",
      "description": "Plugin version that produced this file (informational)."
    },
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Contract version. Consumers should fail-soft on mismatch."
    },
    "session": {
      "type": "object",
      "required": ["id", "question", "language", "started_at", "mode", "complexity"],
      "properties": {
        "id": {"type": "string"},
        "question": {"type": "string"},
        "language": {"type": "string", "description": "IETF BCP 47 tag (e.g. pt-BR, en)."},
        "started_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": ["string", "null"], "format": "date-time"},
        "mode": {"enum": ["Express", "Quick", "Standard", "Complete", "Complete+", "Rechallenge"]},
        "complexity": {"enum": ["Trivial", "Simple", "Moderate", "High", "Very High"]}
      }
    },
    "context": {
      "type": "object",
      "required": ["stage"],
      "properties": {
        "stage": {"enum": ["POC", "MVP", "Full"]},
        "team_size": {"type": ["integer", "null"]},
        "team_expertise": {"type": "array", "items": {"type": "string"}},
        "constraints": {"type": "array", "items": {"type": "string"}},
        "detected_stack": {"type": "array", "items": {"type": "string"}},
        "assumptions_recorded": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "confirmed"],
            "properties": {
              "text": {"type": "string"},
              "confirmed": {"type": "boolean"}
            }
          }
        }
      }
    },
    "landscape": {
      "type": "object",
      "required": ["shortlist"],
      "properties": {
        "shortlist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"},
              "version": {"type": "string"},
              "confidence": {"$ref": "#/$defs/confidence"},
              "stage_fit": {"type": "string"}
            }
          }
        },
        "discarded": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "reason"],
            "properties": {
              "name": {"type": "string"},
              "reason": {"type": "string"},
              "criterion": {"type": "string"},
              "confidence": {"$ref": "#/$defs/confidence"}
            }
          }
        }
      }
    },
    "champions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "archetype", "stack", "strengths", "weaknesses"],
        "properties": {
          "name": {"type": "string"},
          "archetype": {"type": "string"},
          "stack": {"type": "string"},
          "strengths": {"type": "array", "items": {"type": "string"}},
          "weaknesses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["weakness", "mitigation"],
              "properties": {
                "weakness": {"type": "string"},
                "mitigation": {"type": "string"}
              }
            }
          },
          "stage_vision": {
            "type": "object",
            "properties": {
              "POC": {"type": "object"},
              "MVP": {"type": "object"},
              "Full": {"type": "object"}
            }
          },
          "readiness_assessment": {
            "description": "Present only when this champion is the Vanguard.",
            "type": "object",
            "properties": {
              "verdict": {"enum": ["production-ready", "near-ready", "experimental"]},
              "maturity_estimate_months": {"type": "integer"},
              "blockers": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "cross_examination": {
      "type": "object",
      "properties": {
        "rounds": {"type": "integer", "minimum": 0},
        "concessions": {"type": "array"},
        "unresolved_points": {"type": "array"}
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["advisor", "champion", "score"],
            "properties": {
              "advisor": {"type": "string"},
              "champion": {"type": "string"},
              "score": {"type": "integer", "minimum": 1, "maximum": 10},
              "rationale_ref": {"type": "string"}
            }
          }
        },
        "divergences": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "champion": {"type": "string"},
              "advisor_a": {"type": "object"},
              "advisor_b": {"type": "object"},
              "delta": {"type": "integer", "minimum": 0},
              "resolved": {"type": "boolean"}
            }
          }
        }
      }
    },
    "recommendation": {
      "type": "object",
      "required": ["primary", "reversibility"],
      "properties": {
        "primary": {
          "type": "object",
          "required": ["stack", "confidence", "rationale"],
          "properties": {
            "stack": {"type": "string"},
            "total_score": {"type": "number"},
            "confidence": {"$ref": "#/$defs/confidence"},
            "rationale": {"type": "string"}
          }
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stack", "when_to_prefer"],
            "properties": {
              "stack": {"type": "string"},
              "total_score": {"type": "number"},
              "when_to_prefer": {"type": "string"}
            }
          }
        },
        "reversibility": {"enum": ["low", "medium", "high"]},
        "pivot_triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "action"],
            "properties": {
              "condition": {"type": "string"},
              "action": {"type": "string"}
            }
          }
        }
      }
    },
    "migration_path": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_stage", "to_stage"],
        "properties": {
          "from_stage": {"enum": ["POC", "MVP", "Full"]},
          "to_stage": {"enum": ["POC", "MVP", "Full"]},
          "effort_days": {"type": "number"},
          "changes": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "probability", "impact"],
        "properties": {
          "description": {"type": "string"},
          "probability": {"enum": ["low", "medium", "high"]},
          "impact": {"enum": ["low", "medium", "high"]},
          "mitigation": {"type": "string"},
          "stage": {"enum": ["POC", "MVP", "Full"]},
          "affected_options": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "unverified_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim"],
        "properties": {
          "claim": {"type": "string"},
          "expected_source": {"type": "string"},
          "impact": {"enum": ["low", "medium", "high"]}
        }
      }
    },
    "auditor_findings": {
      "type": "array",
      "description": "Required and non-empty in Complete/Complete+/Rechallenge modes.",
      "items": {
        "type": "object",
        "required": ["severity", "finding"],
        "properties": {
          "severity": {"enum": ["critical", "moderate", "informational"]},
          "finding": {"type": "string"},
          "addressed_in_section": {"type": ["string", "null"]},
          "dismissed_reason": {"type": ["string", "null"]}
        }
      }
    },
    "supervisor_dissent": {
      "type": ["object", "null"],
      "properties": {
        "identified_bias": {"type": "string"},
        "overlooked_angle": {"type": "string"},
        "proposed_reranking": {"type": "array"},
        "evidence": {"type": "array"},
        "severity": {"enum": ["critical", "moderate", "informational"]}
      }
    },
    "adr_path": {
      "type": ["string", "null"],
      "description": "Relative path to the MADR ADR for this decision. Null for Express/Quick modes where ADR generation is optional."
    },
    "consumable_hints": {
      "type": "object",
      "description": "Optional hints for external tools (task generators, dashboards).",
      "properties": {
        "task_generators": {"type": "object"}
      }
    }
  },
  "$defs": {
    "confidence": {
      "enum": ["high-conf", "med-conf", "low-conf", "unverified"]
    }
  }
}
